# ===== Shared Infrastructure Connection (must match gitlab-shared/.env) =====
POSTGRES_DB=gitlabhq_production
POSTGRES_USER=gitlab
POSTGRES_PASSWORD=

REDIS_PASSWORD=

MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# host:port reachable from this app node — use the minio *service* name
# ("minio", per gitlab-shared/docker-compose.yml), not its container_name
# ("gitlab_minio"). The mc client (used by the backup sidecar) and some S3
# SDK paths reject underscores as an invalid hostname even though Docker's
# own embedded DNS resolves container_name fine.
GITLAB_MINIO_ENDPOINT=minio:9000

# ===== GitLab Core =====
GITLAB_VERSION=latest
GITLAB_HOSTNAME=gitlab.example.com
# Public URL end users and git clients will use.
GITLAB_EXTERNAL_URL=http://gitlab.example.com
GITLAB_HTTP_PORT=18300
GITLAB_SSH_PORT=2224
GITLAB_DB_HOST=gitlab_postgres
GITLAB_REDIS_HOST=gitlab_redis
GITLAB_BACKUP_KEEP_SECONDS=604800

# ===== Container Registry (optional) =====
GITLAB_REGISTRY_ENABLE=false
GITLAB_REGISTRY_EXTERNAL_URL=

# ===== CI/CD Runner =====
# Get this from Admin Area > CI/CD > Runners (classic registration token) after
# first boot. If the button/token is not visible, enable it first:
# Admin Area > Settings > CI/CD > "Allow runner registration token".
GITLAB_RUNNER_REGISTRATION_TOKEN=
GITLAB_RUNNER_NAME=mlcv-runner-1
GITLAB_RUNNER_TAGS=mlcv,docker
GITLAB_RUNNER_DEFAULT_IMAGE=alpine:latest

# ===== Backup sidecar =====
GITLAB_BACKUP_SCHEDULE_SECONDS=86400
