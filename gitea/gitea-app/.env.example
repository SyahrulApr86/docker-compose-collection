# ===== Shared Infrastructure Connection =====
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

REDIS_PASSWORD=

MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Keep these identical on every app node.
GITEA_SECRET_KEY=
GITEA_INTERNAL_TOKEN=
GITEA_OAUTH2_JWT_SECRET=
LFS_JWT_SECRET=

# ===== Gitea Configuration =====
# Public reverse-proxy defaults for the current host.
GITEA_DOMAIN=
GITEA_ROOT_URL=
# Internal URL used by colocated services such as the built-in Actions runner.
GITEA_HTTP_PORT=
GITEA_SSH_PORT=
GITEA_LOCAL_ROOT_URL=

# ===== External Dependency Endpoints =====
# For same-host deployment with gitea-shared, these defaults expect docker-compose.lab.yml
# and use the shared-stack service DNS names on that Docker network.
# For real HA, point them to your HA PostgreSQL/Redis/MinIO endpoints instead.
GITEA_DB_HOST=
GITEA_DB_SSL_MODE=
GITEA_REDIS_HOST=
GITEA_MINIO_ENDPOINT=
GITEA_MINIO_BUCKET=
GITEA_MINIO_USE_SSL=
GITEA_MINIO_BUCKET_LOOKUP_TYPE=
GITEA_SHARED_NETWORK=
GITEA_PROXY_NETWORK=

# ===== Actions / Runner =====
# Keep the registration token identical on every app node that should auto-register a runner.
GITEA_RUNNER_REGISTRATION_TOKEN=
# Same-host lab can talk to the colocated Gitea service over the compose network.
# For a separate runner host, point this to the public Gitea URL instead.
GITEA_RUNNER_INSTANCE_URL=
# Use a unique runner name per node in real HA deployments.
GITEA_RUNNER_NAME=
GITEA_RUNNER_LABELS=
GITEA_ACTIONS_LOG_MINIO_BASE_PATH=
# Maximum size for OCI image uploads. `-1` means unlimited.
GITEA_CONTAINER_REGISTRY_LIMIT_SIZE=

# ===== HA Storage Layout =====
# Shared mounts must exist at the same absolute path on every app node.
GITEA_SHARED_CONF_PATH=
GITEA_SHARED_REPO_PATH=

# Node-local data can stay local on each VM/container host.
GITEA_NODE_DATA_PATH=
GITEA_RUNNER_DATA_PATH=

# Match these IDs to the owner you want on the mounted directories.
GITEA_UID=
GITEA_GID=