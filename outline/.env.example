# ============================================================
# Outline Wiki — environment variables
# Copy to .env and fill in the values
# ============================================================

# ── App ──────────────────────────────────────────────────────
# Public URL where Outline is accessible
URL=http://localhost:3000

# Generate with: openssl rand -hex 32
SECRET_KEY=
UTILS_SECRET=

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=outline
POSTGRES_PASSWORD=changeme
POSTGRES_DB=outline

# ── File storage ─────────────────────────────────────────────
# "local" stores files on disk; "s3" for S3-compatible storage
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000

# ── SMTP (optional — needed for email sign-in / notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=hello@example.com
SMTP_SECURE=false

# ── OIDC — Keycloak ──────────────────────────────────────────
# Client ID and secret from Keycloak (realm → clients → outline)
OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=

# Replace <HOST> and <REALM> with your Keycloak host and realm name
OIDC_AUTH_URI=http://<HOST>:8080/realms/<REALM>/protocol/openid-connect/auth
OIDC_TOKEN_URI=http://<HOST>:8080/realms/<REALM>/protocol/openid-connect/token
OIDC_USERINFO_URI=http://<HOST>:8080/realms/<REALM>/protocol/openid-connect/userinfo
OIDC_LOGOUT_URI=http://<HOST>:8080/realms/<REALM>/protocol/openid-connect/logout
OIDC_USERNAME_CLAIM=preferred_username
OIDC_DISPLAY_NAME=Keycloak
OIDC_SCOPES=openid profile email

# ── Keycloak ─────────────────────────────────────────────────
KC_REALM=magnolia
KC_ADMIN=admin
KC_ADMIN_PASSWORD=changeme
KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=changeme
KC_POSTGRES_DB=keycloak
